# Mini App config. Copy to .env (gitignored) and fill in.

# Backend API URL. Empty = relative paths (uses vite dev proxy at /api).
# In production this is the full https origin of the API server.
VITE_API_URL=

# Reown / WalletConnect project ID. Free at https://cloud.reown.com.
# Without this, the Mini App falls back to injected-only connectors
# (extension wallets in same-tab; mobile wallets won't work).
VITE_REOWN_PROJECT_ID=
