# tg-token v2 — local dev .env. Copy to .env and fill in.

# --- Telegram ---
# Register a dev bot with @BotFather → /newbot. Paste the token here.
BOT_TOKEN=

# Comma- or space-separated Telegram user IDs allowed to issue owner-only DMs.
# Find your own ID by DMing @userinfobot.
OWNER_TG_IDS=

# --- Persistence ---
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=tg_token

REDIS_URL=redis://127.0.0.1:6379/0

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Chains (filled in later sessions) ---
# Session 3+:
ALCHEMY_API_KEY=
ALCHEMY_WEBHOOK_SIGNING_KEY=
# Session 6+:
HELIUS_API_KEY=
HELIUS_WEBHOOK_SIGNING_KEY=
# Session 7+:
TON_API_KEY=

# --- Mini App (session 2+) ---
# Public URL where the React Mini App is hosted (e.g. Vercel).
WEBAPP_URL=
# Verifier sidecar (Node + viem ≥ 2.x for EIP-1271/6492).
VERIFIER_URL=http://127.0.0.1:8090
