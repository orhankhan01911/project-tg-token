# tg-token v2 — local dev .env. Copy to .env and fill in.

# --- Telegram ---
BOT_TOKEN=
OWNER_TG_IDS=

# --- Persistence ---
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=tg_token
REDIS_URL=redis://127.0.0.1:6379/0

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Chains ---
# Alchemy free tier: https://dashboard.alchemy.com/apps
# Empty = use the chain's free public RPC (throttled — fine for v0 dev).
ALCHEMY_API_KEY=
HELIUS_API_KEY=

# Default chain ID for dust verification. 84532 = Base Sepolia (testnet).
DUST_CHAIN_ID=84532
