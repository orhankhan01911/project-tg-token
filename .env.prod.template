# Copy this to .env.prod on the Hetzner server and fill in real values.
# DO NOT commit .env.prod to git — this template only has placeholders.

BOT_TOKEN=YOUR_BOT_TOKEN_HERE
OWNER_TG_IDS=YOUR_TELEGRAM_USER_ID

# Mongo + Redis URIs are overridden by docker-compose.prod.yml — leave as-is
MONGO_DB=tg_token
LOG_LEVEL=INFO

SENTRY_DSN=

ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
HELIUS_API_KEY=YOUR_HELIUS_KEY

# Optional — flip to 8453 for Base mainnet, 1 for Ethereum mainnet
# DUST_CHAIN_ID=8453

# Daily purge hour (UTC, 0-23)
PURGE_HOUR_UTC=0
